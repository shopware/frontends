{
  "name": "@shopware/cms-base-layer",
  "version": "3.0.1",
  "description": "Vue CMS Nuxt Layer for Shopware",
  "author": "Shopware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "homepage": "https://frontends.shopware.com/framework/shopping-experiences.html",
  "keywords": [
    "Shopware",
    "Vue",
    "CMS",
    "Nuxt",
    "Layer"
  ],
  "bugs": {
    "url": "https://github.com/shopware/frontends/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./nuxt.config.ts",
  "files": [
    "dist",
    "app",
    "helpers",
    "index.cjs",
    "index.d.ts",
    "app.config.ts",
    "nuxt.config.ts",
    "uno.config.ts"
  ],
  "scripts": {
    "build": "nuxt prepare && unbuild",
    "dev": "unbuild --stub",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write . && pnpm run typecheck",
    "typecheck": "pnpm nuxt prepare && tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-colors": "tsx scripts/check-unused-colors.ts"
  },
  "dependencies": {
    "@iconify-json/carbon": "1.2.23",
    "@nuxt/image": "2.0.0",
    "@nuxt/kit": "4.4.8",
    "@shopware/api-client": "workspace:*",
    "@shopware/composables": "workspace:*",
    "@shopware/helpers": "workspace:*",
    "@tresjs/cientos": "5.7.2",
    "@tresjs/nuxt": "^5.6.1",
    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
    "@vueuse/core": "14.3.0",
    "entities": "6.0.0",
    "scule": "1.3.0",
    "html-to-ast": "0.0.6",
    "three": "0.183.2",
    "vue": "3.5.38",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@nuxt/schema": "4.4.8",
    "@types/three": "0.182.0",
    "@typescript/native-preview": "7.0.0-dev.20260205.1",
    "@vitest/coverage-v8": "4.1.9",
    "nuxt": "4.4.8",
    "tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "unbuild": "3.6.1",
    "vitest": "4.1.9",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.5"
  }
}
