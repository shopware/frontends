    "@unocss/runtime": "66.6.0",
    "unocss": "66.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@nuxt/schema": "4.2.2",
    "@typescript/native-preview": "7.0.0-dev.20260205.1",
    "nuxt": "4.2.2",
    "tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "unbuild": "2.0.0"
  }
}
