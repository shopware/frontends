{
  "name": "@shopware/unocss-design-tokens-layer",
  "version": "1.0.0",
  "description": "Reusable Nuxt Layer for Shopware design tokens and UnoCSS configuration",
  "author": "Shopware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "homepage": "https://frontends.shopware.com/",
  "keywords": ["Shopware", "UnoCSS", "Nuxt", "Layer", "Design Tokens"],
