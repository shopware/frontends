    "typecheck": "pnpm nuxt prepare && tsgo --noEmit"
  },
  "dependencies": {
    "@unocss/nuxt": "66.7.4",
    "@unocss/core": "66.7.4",
    "@unocss/preset-wind3": "66.7.4",
    "@unocss/runtime": "66.7.4",
    "unocss": "66.7.4"
  },
  "devDependencies": {
    "@nuxt/schema": "4.4.8",
    "@typescript/native-preview": "7.0.0-dev.20260205.1",
    "nuxt": "4.4.8",
    "tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "unbuild": "3.6.1"
  }
}
