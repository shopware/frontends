# Sanity project - editorial content / page builder.
# A public dataset needs no token for the frontend to read.
NUXT_SANITY_PROJECT_ID="0celbjjf"
NUXT_SANITY_DATASET="production"

# Optional: Sanity API token used ONLY by CLI tooling (schema deploy, seeding
# content) - NOT by the Nuxt frontend. This is a SECRET; never commit the real
# value. Create one at https://www.sanity.io/manage/project/0celbjjf
# (API > Tokens, "Editor" permissions).
SANITY_AUTH_TOKEN=
