    "@shopware/composables": "canary",
    "@shopware/nuxt-module": "canary",
    "@unocss/nuxt": "66.7.4",
    "braintree-web-drop-in": "^1.46.0",
    "nuxt": "4.4.8",
    "vue-tsc": "3.3.5",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0"
  }
}
