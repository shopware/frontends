{
  "private": true,
  "name": "example-adyen-dropin-playground",
  "type": "module",
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write .",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "generate": "nuxt generate",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "devDependencies": {
    "@adyen/adyen-web": "6.41.0",
    "@shopware/composables": "canary",
    "@shopware/nuxt-module": "canary",
    "@shopware/api-client": "canary",
    "@shopware/api-gen": "canary",
    "@unocss/nuxt": "66.7.5",
    "nuxt": "4.5.0",
    "vue-tsc": "3.3.7",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0"
  }
}
