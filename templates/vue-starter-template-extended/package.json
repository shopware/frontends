{
  "name": "lumora-demo-store",
  "version": "0.0.2",
  "description": "Lumora Demo Store - Modern Home Scents",
  "private": true,
  "author": "Shopware",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.16.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "main": "./nuxt.config.ts",
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write . && pnpm run typecheck",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "dependencies": {
    "@shopware/api-client": "canary",
    "@shopware/composables": "canary",
    "@shopware/helpers": "canary",
    "@shopware/nuxt-module": "canary",
    "nuxt": "4.2.2",
    "vue": "3.5.27",
    "vue-starter-template": "file:./base-template"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/i18n": "10.0.1",
    "@shopware/api-gen": "canary",
    "@shopware/cms-base-layer": "canary",
    "@unocss/nuxt": "66.6.0",
    "@vueuse/core": "14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "typescript": "5.9.3",
    "unocss": "66.6.0",
    "vue-tsc": "3.2.2"
  }
}
