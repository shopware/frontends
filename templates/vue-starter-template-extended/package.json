{
  "name": "lumora-demo-store",
  "version": "0.0.4",
  "description": "Lumora Demo Store - Modern Home Scents",
  "private": true,
  "author": "Shopware",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "main": "./nuxt.config.ts",
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write . && pnpm run typecheck",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "dependencies": {
    "nuxt": "4.4.8",
    "vue": "3.5.38",
    "vue-starter-template": "workspace:*"
  },
  "devDependencies": {
    "@shopware/api-gen": "canary",
    "@unocss/core": "66.7.2",
    "typescript": "5.9.3",
    "vue-tsc": "3.3.5",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0"
  },
  "overrides": {
    "glob": "^13",
    "eslint-visitor-keys": "^4"
  }
}
