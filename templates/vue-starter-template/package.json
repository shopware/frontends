{
  "name": "vue-starter-template",
  "version": "0.1.2",
  "description": "Shopware Vue Starter Template",
  "private": true,
  "author": "Shopware",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts",
    "./uno.config": "./uno.config.ts"
  },
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write . && pnpm run typecheck",
    "typecheck": "nuxt prepare && nuxi typecheck",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "dependencies": {
    "@iconify-json/carbon": "1.2.24",
    "@iconify/utils": "3.1.4",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/icon": "2.3.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/vite-builder": "4.4.8",
    "@nuxtjs/i18n": "10.4.0",
    "@regle/core": "1.25.2",
    "@regle/rules": "1.25.2",
    "@shopware/api-client": "canary",
    "@shopware/cms-base-layer": "canary",
    "@shopware/composables": "canary",
    "@shopware/helpers": "canary",
    "@shopware/nuxt-module": "canary",
    "@shopware/unocss-design-tokens-layer": "canary",
    "@unocss/core": "66.7.5",
    "@unocss/nuxt": "66.7.5",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "nuxt": "4.4.8",
    "scule": "1.3.0",
    "unocss": "66.7.5",
    "vue": "3.5.40"
  },
  "devDependencies": {
    "@shopware/api-gen": "canary",
    "@vue/compiler-sfc": "3.5.40",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vue-tsc": "3.3.7"
  },
  "overrides": {
    "glob": "^13",
    "eslint-visitor-keys": "^4"
  }
}
