{
  "name": "vue-starter-template",
  "version": "0.1.0",
  "description": "Shopware Vue Starter Template",
  "private": true,
  "author": "Shopware",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopware/frontends.git"
  },
  "main": "./nuxt.config.ts",
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write . && pnpm run typecheck",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "dependencies": {
    "@iconify-json/carbon": "1.2.21",
    "@iconify/utils": "3.1.3",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/icon": "2.2.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/vite-builder": "4.4.5",
    "@nuxtjs/i18n": "10.3.0",
    "@regle/core": "1.25.2",
    "@regle/rules": "1.25.2",
    "@shopware/api-client": "canary",
    "@shopware/cms-base-layer": "canary",
    "@shopware/composables": "canary",
    "@shopware/helpers": "canary",
    "@shopware/nuxt-module": "canary",
    "@shopware/unocss-design-tokens-layer": "canary",
    "@unocss/nuxt": "66.6.8",
    "@unocss/core": "66.6.8",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "nuxt": "4.4.6",
    "unocss": "66.6.8",
    "vue": "3.5.34"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@shopware/api-gen": "canary",
    "@vue/compiler-sfc": "3.5.34",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vue-tsc": "3.2.9"
  },
  "overrides": {
    "glob": "^13",
    "vue-i18n": "^11",
    "eslint-visitor-keys": "^4"
  }
}
