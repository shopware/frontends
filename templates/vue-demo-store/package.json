{
  "name": "vue-demo-store",
  "version": "1.14.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build",
    "start": "nuxt start",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write . && pnpm run typecheck",
    "typecheck": "nuxt prepare && nuxi typecheck",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "analyze": "nuxt analyze",
    "generate-types": "shopware-api-gen generate --apiType=store"
  },
  "dependencies": {
    "@shopware/api-client": "canary",
    "@shopware/cms-base-layer": "canary",
    "@shopware/composables": "canary",
    "@shopware/helpers": "canary",
    "@shopware/nuxt-module": "canary",
    "@unocss/core": "66.7.4",
    "@unocss/nuxt": "66.7.4",
    "@unocss/transformer-directives": "66.7.4",
    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
    "@vueuse/nuxt": "14.3.0",
    "defu": "6.1.7",
    "requrl": "3.0.2",
    "sitemap": "8.0.0",
    "unocss": "66.7.4",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@iconify-json/carbon": "1.2.23",
    "@iconify/utils": "3.1.3",
    "@nuxtjs/i18n": "10.4.0",
    "@shopware/api-gen": "canary",
    "nuxt": "4.4.8",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0"
  },
  "engines": {
    "node": "^20.x || ^22.x || ^24.x"
  }
}
