{
  "name": "Shopware Vue Starter Template",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "workspaceFolder": "/workspaces/frontends/templates/vue-starter-template",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "npm install -g pnpm",
  "postAttachCommand": "pnpm install && pnpm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Storefront",
      "onAutoForward": "openBrowserOnce"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": ["vue.volar", "antfu.unocss"]
    }
  }
}
